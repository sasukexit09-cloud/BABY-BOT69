const axios = require("axios");

module.exports = {
  config: {
    name: "twixtor",
    version: "1.0",
    author: "Fix",
    category: "fun",
    guide: { en: "{p}twixtor [name]" }
  },

  onStart: async function ({ api, event, args }) {
    try {

      api.setMessageReaction("⏳", event.messageID, () => {}, true);

      const query = args.join(" ");
      if (!query)
        return api.sendMessage("⚠️ | Enter a search keyword", event.threadID, event.messageID);

      // STEP 1 — GET VIDEO LIST
      const res = await axios.get(
        "https://lyric-search-neon.vercel.app/kshitiz?keyword=" +
        encodeURIComponent(query + " anime twixtor")
      );

      const videos = res.data;

      if (!videos || videos.length === 0)
        return api.sendMessage("❌ | No video found", event.threadID, event.messageID);

      const videoUrl = videos[Math.floor(Math.random() * videos.length)].videoUrl;

      // STEP 2 — STREAM DOWNLOAD (MOST STABLE)
      const stream = await axios({
        url: videoUrl,
        method: "GET",
        responseType: "stream",
        timeout: 60000
      });

      api.setMessageReaction("🍓", event.messageID, () => {}, true);

      return api.sendMessage({
        body: "✨ Twixtor Ready",
        attachment: stream.data
      }, event.threadID, event.messageID);

    } catch (err) {
      console.log(err);
      return api.sendMessage("🌷" | Command error", event.threadID, event.messageID);
    }
  }
};